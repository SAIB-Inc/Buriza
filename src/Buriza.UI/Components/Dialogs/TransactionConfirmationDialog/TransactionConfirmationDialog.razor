@using Buriza.UI.Components.Controls
@using Buriza.UI.Resources

@namespace Buriza.UI.Components.Dialogs

<BurizaBaseDialog 
    Title="Transaction Confirmation"
    OnClose="Cancel" 
    Class="w-[314px] min-[425px]:w-[379px] !p-6" 
    TitleClass="p-0! min-[425px]:mb-3!"
    ActionsClass="!justify-end px-0! pt-0! pb-0!"
>
    <DialogContent>
        <div class="h-full flex flex-col !gap-y-6">
            <div>
                <MudText
                    Class="text-xs! tracking-[0.1px] break-words !text-center min-[425px]:!text-start"
                >
                    Please sign the transaction with your password
                </MudText>
            </div>
            <div class="relative !mb-6">
                <BurizaPasswordField/>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <BurizaButton Class="flex-1 bg-[var(--mud-palette-overlay-light)]! text-[var(--mud-palette-text-primary)]!" OnClick="Cancel">Cancel</BurizaButton>
        <BurizaButton Class="flex-1" Color="Color.Primary" OnClick="Confirm">Confirm</BurizaButton>
    </DialogActions>
</BurizaBaseDialog>